generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockLevels  StockLevel[]
  reservations Reservation[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String   @unique
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockLevels  StockLevel[]
  reservations Reservation[]
}

// Stock per product per warehouse
model StockLevel {
  id          String @id @default(cuid())
  productId   String
  warehouseId String
  totalUnits  Int    @default(0)
  // reserved units = sum of pending reservations; computed on read
  // We store reservedUnits as a denormalised counter for fast reads,
  // updated atomically with the reservation row.
  reservedUnits Int  @default(0)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

enum ReservationStatus {
  pending
  confirmed
  released
}

model Reservation {
  id          String            @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int
  status      ReservationStatus @default(pending)
  expiresAt   DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Optional: idempotency key supplied by the client
  idempotencyKey String? @unique

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}
